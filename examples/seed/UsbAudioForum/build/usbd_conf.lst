   1:usbd_conf.c   **** /**
   2:usbd_conf.c   ****   ******************************************************************************
   3:usbd_conf.c   ****   * @file    usbd_conf.c
   4:usbd_conf.c   ****   * @brief   USB Device board support / PCD glue layer for Daisy Seed UAC1
   5:usbd_conf.c   ****   *
   6:usbd_conf.c   ****   * Changes from libDaisy CDC baseline:
   7:usbd_conf.c   ****   *  1. Sof_enable = ENABLE  — audio class USBD_AUDIO_SOF() needs SOF events
   8:usbd_conf.c   ****   *  2. TX FIFO 1 enlarged    — audio IN packets are 192 bytes; old 0x80 (128B)
   9:usbd_conf.c   ****   *                             was borderline; 0xC0 (192B) gives clean headroom
  10:usbd_conf.c   ****   *  3. vbus_sensing_enable   — left ENABLE for FS (Daisy has VBUS sense on PA9)
  11:usbd_conf.c   ****   *  4. HS init removed       — Daisy Seed only has the FS connector exposed;
  12:usbd_conf.c   ****   *                             keep the HS block for completeness but it's unused
  13:usbd_conf.c   ****   ******************************************************************************
  14:usbd_conf.c   ****   */
  15:usbd_conf.c   **** 
