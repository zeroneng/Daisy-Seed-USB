 164:usbd_audio.c  **** static uint8_t USBD_AUDIO_Setup(USBD_HandleTypeDef *pdev, USBD_SetupReqTypedef *req)
 165:usbd_audio.c  **** {
 166:usbd_audio.c  ****     USBD_AUDIO_HandleTypeDef *haudio = HAUDIO;
 167:usbd_audio.c  ****     uint16_t len;
 168:usbd_audio.c  ****     uint16_t status_info = 0U;
 169:usbd_audio.c  ****     USBD_StatusTypeDef ret = USBD_OK;
 170:usbd_audio.c  **** 
 171:usbd_audio.c  ****     if(haudio == NULL) return USBD_FAIL;
 172:usbd_audio.c  **** 
 173:usbd_audio.c  ****     switch(req->bmRequest & USB_REQ_TYPE_MASK)
 174:usbd_audio.c  ****     {
 175:usbd_audio.c  ****         case USB_REQ_TYPE_CLASS:
 176:usbd_audio.c  ****             switch(req->bRequest) {
 177:usbd_audio.c  ****                 case AUDIO_REQ_GET_CUR: AUDIO_REQ_GetCurrent(pdev, req); break;
 178:usbd_audio.c  ****                 case AUDIO_REQ_SET_CUR: AUDIO_REQ_SetCurrent(pdev, req); break;
 179:usbd_audio.c  ****                 default: USBD_CtlError(pdev, req); ret = USBD_FAIL; break;
 180:usbd_audio.c  ****             }
 181:usbd_audio.c  ****             break;
 182:usbd_audio.c  **** 
 183:usbd_audio.c  ****         case USB_REQ_TYPE_STANDARD:
 184:usbd_audio.c  ****             switch(req->bRequest) {
 185:usbd_audio.c  ****                 case USB_REQ_GET_STATUS:
 186:usbd_audio.c  ****                     if(pdev->dev_state == USBD_STATE_CONFIGURED)
 187:usbd_audio.c  ****                         USBD_CtlSendData(pdev, (uint8_t *)&status_info, 2U);
 188:usbd_audio.c  ****                     else { USBD_CtlError(pdev, req); ret = USBD_FAIL; }
 189:usbd_audio.c  ****                     break;
 190:usbd_audio.c  **** 
 191:usbd_audio.c  ****                 case USB_REQ_GET_DESCRIPTOR:
 192:usbd_audio.c  ****                     if((req->wValue >> 8) == AUDIO_DESCRIPTOR_TYPE) {
 193:usbd_audio.c  ****                         len = MIN(USB_AUDIO_DESC_SIZ, req->wLength);
 194:usbd_audio.c  ****                         USBD_CtlSendData(pdev, USBD_AUDIO_CfgDesc + 18U, len);
