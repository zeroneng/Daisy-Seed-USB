 229:usbd_audio.c  **** /* -----------------------------------------------------------------------
 230:usbd_audio.c  ****  * DataIn — called after host consumes each isochronous packet
 231:usbd_audio.c  ****  *
 232:usbd_audio.c  ****  * Changes from working baseline:
 233:usbd_audio.c  ****  *
 234:usbd_audio.c  ****  *   1. XOR toggle replaced with explicit 0/AUDIO_PACKET_MAX alternation.
 235:usbd_audio.c  ****  *      Old: haudio->wr_ptr ^= AUDIO_OUT_PACKET  (only correct when both
 236:usbd_audio.c  ****  *           slots are exactly 192 bytes apart; breaks with 196-byte slots)
 237:usbd_audio.c  ****  *      New: explicit ternary toggle between 0 and AUDIO_PACKET_MAX
 238:usbd_audio.c  ****  *
 239:usbd_audio.c  ****  *   2. PeriodicTC return value captured and passed to USBD_LL_Transmit.
 240:usbd_audio.c  ****  *      Old: return value discarded, AUDIO_OUT_PACKET (192) always sent
 241:usbd_audio.c  ****  *      New: actual byte count (188/192/196) reaches the wire
 242:usbd_audio.c  ****  *
 243:usbd_audio.c  ****  *   3. last_tx_size saved for IsoINIncomplete re-submission.
 244:usbd_audio.c  ****  * --------------------------------------------------------------------- */
 245:usbd_audio.c  **** static uint8_t USBD_AUDIO_DataIn(USBD_HandleTypeDef *pdev, uint8_t epnum)
 246:usbd_audio.c  **** {
 247:usbd_audio.c  ****     (void)epnum;
 248:usbd_audio.c  ****     USBD_AUDIO_HandleTypeDef *haudio = HAUDIO;
 249:usbd_audio.c  ****     if(haudio == NULL || !audio_streaming_active) return USBD_OK;
 250:usbd_audio.c  **** 
 251:usbd_audio.c  ****     haudio->wr_ptr = (haudio->wr_ptr == 0U) ? AUDIO_PACKET_MAX : 0U;
 252:usbd_audio.c  **** 
 253:usbd_audio.c  ****     last_tx_size = ITFOPS->PeriodicTC(
 254:usbd_audio.c  ****         &haudio->buffer[haudio->wr_ptr], AUDIO_PACKET_MAX, AUDIO_IN_TC);
 255:usbd_audio.c  **** 
 256:usbd_audio.c  ****     /* Flush D-cache for this buffer slot before DMA reads it.
 257:usbd_audio.c  ****        Without this, USB DMA reads stale data from physical SRAM
 258:usbd_audio.c  ****        while the CPU cache holds the fresh data from PeriodicTC. */
ARM GAS  /tmp/ccUUe33m.s 			page 6


 259:usbd_audio.c  ****     SCB_CleanDCache_by_Addr(
 260:usbd_audio.c  ****         (uint32_t *)&haudio->buffer[haudio->wr_ptr], last_tx_size);
 261:usbd_audio.c  **** 
 262:usbd_audio.c  ****     USBD_LL_Transmit(pdev, AUDIO_IN_EP,
 263:usbd_audio.c  ****                      &haudio->buffer[haudio->wr_ptr], last_tx_size);
 264:usbd_audio.c  ****     return USBD_OK;
 265:usbd_audio.c  **** }
 266:usbd_audio.c  **** /* -----------------------------------------------------------------------
 267:usbd_audio.c  ****  * IsoINIncomplete — packet was lost on the bus (USB frame overrun)
 268:usbd_audio.c  ****  *
 269:usbd_audio.c  ****  * Re-submit the current slot verbatim. Do NOT call PeriodicTC — that
 270:usbd_audio.c  ****  * would drain an extra packet from the ring buffer causing underrun.
 271:usbd_audio.c  ****  * Use last_tx_size so the re-submitted packet matches the original size.
 272:usbd_audio.c  ****  * --------------------------------------------------------------------- */
 273:usbd_audio.c  **** static uint8_t USBD_AUDIO_IsoINIncomplete(USBD_HandleTypeDef *pdev, uint8_t epnum)
 274:usbd_audio.c  **** {
 275:usbd_audio.c  ****     (void)epnum;
 276:usbd_audio.c  ****     USBD_AUDIO_HandleTypeDef *haudio = HAUDIO;
 277:usbd_audio.c  ****     if(haudio == NULL || !audio_streaming_active) return USBD_OK;
 278:usbd_audio.c  **** 
 279:usbd_audio.c  ****     USBD_LL_FlushEP(pdev, AUDIO_IN_EP);
 280:usbd_audio.c  ****     USBD_LL_Transmit(pdev, AUDIO_IN_EP,
 281:usbd_audio.c  ****                      &haudio->buffer[haudio->wr_ptr], last_tx_size);
 282:usbd_audio.c  ****     return USBD_OK;
 283:usbd_audio.c  **** }
 284:usbd_audio.c  **** 
 285:usbd_audio.c  **** /* -----------------------------------------------------------------------
 286:usbd_audio.c  ****  * Stubs — identical to working baseline
