  31:usbd_audio.c  **** /* -----------------------------------------------------------------------
  32:usbd_audio.c  ****  * Configuration descriptor — 109 bytes, UAC1 stereo mic 16-bit 48kHz
  33:usbd_audio.c  ****  *
  34:usbd_audio.c  ****  * Changes from working baseline (usbd_audio.c 1771962245333):
  35:usbd_audio.c  ****  *
  36:usbd_audio.c  ****  *   [offset 65] bmAttributes:  0x01 → 0x05
  37:usbd_audio.c  ****  *     0x01 = synchronous isochronous (device slaved to host SOF)
  38:usbd_audio.c  ****  *     0x05 = asynchronous isochronous (device controls rate)
  39:usbd_audio.c  ****  *     Async is required for variable packet size to be valid. With sync
  40:usbd_audio.c  ****  *     the host may enforce exactly 192 bytes and discard 196-byte packets.
  41:usbd_audio.c  ****  *
  42:usbd_audio.c  ****  *   [offset 66-67] wMaxPacketSize: 0xC0 0x00 (192) → 0xC4 0x00 (196)
  43:usbd_audio.c  ****  *     Must fit the largest packet we will ever send (49 frames × 4 bytes).
  44:usbd_audio.c  ****  *     The host uses this to allocate its receive buffer. Sending 196 bytes
  45:usbd_audio.c  ****  *     to an endpoint declared as 192 causes silent packet loss.
  46:usbd_audio.c  ****  * --------------------------------------------------------------------- */
  47:usbd_audio.c  **** __ALIGN_BEGIN static uint8_t USBD_AUDIO_CfgDesc[USB_AUDIO_CONFIG_DESC_SIZ] __ALIGN_END = {
  48:usbd_audio.c  ****     /* Configuration (9) */
  49:usbd_audio.c  ****     0x09, USB_DESC_TYPE_CONFIGURATION,
  50:usbd_audio.c  ****     LOBYTE(USB_AUDIO_CONFIG_DESC_SIZ), HIBYTE(USB_AUDIO_CONFIG_DESC_SIZ),
  51:usbd_audio.c  ****     0x02, 0x01, 0x00, 0xC0, 50U,
  52:usbd_audio.c  **** 
  53:usbd_audio.c  ****     /* AudioControl Interface (9) */
  54:usbd_audio.c  ****     0x09, USB_DESC_TYPE_INTERFACE, 0x00, 0x00, 0x00,
  55:usbd_audio.c  ****     USB_DEVICE_CLASS_AUDIO, AUDIO_SUBCLASS_AUDIOCONTROL, AUDIO_PROTOCOL_UNDEFINED, 0x00,
  56:usbd_audio.c  **** 
  57:usbd_audio.c  ****     /* AC Header (9) */
  58:usbd_audio.c  ****     0x09, AUDIO_INTERFACE_DESCRIPTOR_TYPE, AUDIO_CONTROL_HEADER,
  59:usbd_audio.c  ****     0x00, 0x01, 0x27, 0x00, 0x01, 0x01,
  60:usbd_audio.c  **** 
  61:usbd_audio.c  ****     /* Input Terminal — Microphone stereo (12) */
  62:usbd_audio.c  ****     0x0C, AUDIO_INTERFACE_DESCRIPTOR_TYPE, AUDIO_CONTROL_INPUT_TERMINAL,
  63:usbd_audio.c  ****     0x01, 0x01, 0x02, 0x00, 0x02, 0x03, 0x00, 0x00, 0x00,
  64:usbd_audio.c  **** 
  65:usbd_audio.c  ****     /* Feature Unit — Mute (9) */
  66:usbd_audio.c  ****     0x09, AUDIO_INTERFACE_DESCRIPTOR_TYPE, AUDIO_CONTROL_FEATURE_UNIT,
  67:usbd_audio.c  ****     0x02, 0x01, 0x01, AUDIO_CONTROL_MUTE, 0x00, 0x00,
  68:usbd_audio.c  **** 
  69:usbd_audio.c  ****     /* Output Terminal — USB Streaming (9) */
  70:usbd_audio.c  ****     0x09, AUDIO_INTERFACE_DESCRIPTOR_TYPE, AUDIO_CONTROL_OUTPUT_TERMINAL,
  71:usbd_audio.c  ****     0x03, 0x01, 0x01, 0x00, 0x02, 0x00,
  72:usbd_audio.c  **** 
  73:usbd_audio.c  ****     /* AudioStreaming Interface alt 0 — zero bandwidth (9) */
  74:usbd_audio.c  ****     0x09, USB_DESC_TYPE_INTERFACE, 0x01, 0x00, 0x00,
  75:usbd_audio.c  ****     USB_DEVICE_CLASS_AUDIO, AUDIO_SUBCLASS_AUDIOSTREAMING, AUDIO_PROTOCOL_UNDEFINED, 0x00,
  76:usbd_audio.c  **** 
  77:usbd_audio.c  ****     /* AudioStreaming Interface alt 1 — active, 1 endpoint (9) */
  78:usbd_audio.c  ****     0x09, USB_DESC_TYPE_INTERFACE, 0x01, 0x01, 0x01,
  79:usbd_audio.c  ****     USB_DEVICE_CLASS_AUDIO, AUDIO_SUBCLASS_AUDIOSTREAMING, AUDIO_PROTOCOL_UNDEFINED, 0x00,
  80:usbd_audio.c  **** 
  81:usbd_audio.c  ****     /* AS General (7) */
  82:usbd_audio.c  ****     0x07, AUDIO_INTERFACE_DESCRIPTOR_TYPE, AUDIO_STREAMING_GENERAL,
  83:usbd_audio.c  ****     0x03, 0x01, 0x01, 0x00,
  84:usbd_audio.c  **** 
  85:usbd_audio.c  ****     /* Type I Format — 2ch 16-bit 48kHz (11) */
  86:usbd_audio.c  ****     0x0B, AUDIO_INTERFACE_DESCRIPTOR_TYPE, AUDIO_STREAMING_FORMAT_TYPE,
  87:usbd_audio.c  ****     AUDIO_FORMAT_TYPE_I, 0x02, 0x02, 16, 0x01,
ARM GAS  /tmp/ccUUe33m.s 			page 3


  88:usbd_audio.c  ****     0x80, 0xBB, 0x00,   /* 48000 = 0x00BB80 little-endian */
  89:usbd_audio.c  **** 
  90:usbd_audio.c  ****     /* ISO IN Endpoint 0x81 (9) */
  91:usbd_audio.c  ****     0x09, USB_DESC_TYPE_ENDPOINT, AUDIO_IN_EP,
  92:usbd_audio.c  ****     0x05,               /* bmAttributes = async isochronous (was 0x01 sync) */
  93:usbd_audio.c  ****     0xC4, 0x00,         /* wMaxPacketSize = 196 (was 0xC0=192) */
  94:usbd_audio.c  ****     0x01, 0x00, 0x00,   /* bInterval=1ms, bRefresh=0, bSynchAddress=0 */
  95:usbd_audio.c  **** 
  96:usbd_audio.c  ****     /* AS Endpoint Descriptor (7) */
  97:usbd_audio.c  ****     0x07, AUDIO_ENDPOINT_DESCRIPTOR_TYPE, AUDIO_ENDPOINT_GENERAL,
  98:usbd_audio.c  ****     0x00, 0x00, 0x00, 0x00,
  99:usbd_audio.c  **** };
 100:usbd_audio.c  **** 
 101:usbd_audio.c  **** __ALIGN_BEGIN static uint8_t USBD_AUDIO_DeviceQualifierDesc[USB_LEN_DEV_QUALIFIER_DESC] __ALIGN_END
 102:usbd_audio.c  ****     USB_LEN_DEV_QUALIFIER_DESC, USB_DESC_TYPE_DEVICE_QUALIFIER,
 103:usbd_audio.c  ****     0x00, 0x02, 0x00, 0x00, 0x00, 0x40, 0x01, 0x00,
 104:usbd_audio.c  **** };
 105:usbd_audio.c  **** 
 106:usbd_audio.c  **** static uint8_t  audio_streaming_active = 0U;
 107:usbd_audio.c  **** 
 108:usbd_audio.c  **** /* Tracks the byte count of the last submitted packet.
 109:usbd_audio.c  ****    IsoINIncomplete re-submits the same slot with the same size — no ring
 110:usbd_audio.c  ****    buffer drain, no double-drain race. */
 111:usbd_audio.c  **** static uint16_t last_tx_size = AUDIO_OUT_PACKET;
 112:usbd_audio.c  **** 
 113:usbd_audio.c  **** /* -----------------------------------------------------------------------
 114:usbd_audio.c  ****  * Init
 115:usbd_audio.c  ****  * --------------------------------------------------------------------- */
 116:usbd_audio.c  **** static uint8_t USBD_AUDIO_Init(USBD_HandleTypeDef *pdev, uint8_t cfgidx)
 117:usbd_audio.c  **** {
 118:usbd_audio.c  ****     (void)cfgidx;
 119:usbd_audio.c  ****     USBD_AUDIO_HandleTypeDef *haudio =
 120:usbd_audio.c  ****         (USBD_AUDIO_HandleTypeDef *)USBD_malloc(sizeof(USBD_AUDIO_HandleTypeDef));
 121:usbd_audio.c  ****     if(haudio == NULL) { pdev->pClassData = NULL; return USBD_FAIL; }
 122:usbd_audio.c  **** 
 123:usbd_audio.c  ****     pdev->pClassData = haudio;
 124:usbd_audio.c  **** 
 125:usbd_audio.c  ****     /* Open endpoint at AUDIO_PACKET_MAX (196) so 49-frame packets are
 126:usbd_audio.c  ****        accepted. Opening at 192 causes silent rejection of 196-byte packets. */
 127:usbd_audio.c  ****     USBD_LL_OpenEP(pdev, AUDIO_IN_EP, USBD_EP_TYPE_ISOC, AUDIO_PACKET_MAX);
 128:usbd_audio.c  ****     pdev->ep_in[AUDIO_IN_EP & 0x7FU].is_used = 1U;
 129:usbd_audio.c  **** 
 130:usbd_audio.c  ****     haudio->alt_setting = 0U;
 131:usbd_audio.c  ****     haudio->offset      = AUDIO_OFFSET_NONE;
 132:usbd_audio.c  ****     haudio->wr_ptr      = 0U;
 133:usbd_audio.c  ****     haudio->rd_ptr      = 0U;
 134:usbd_audio.c  ****     haudio->rd_enable   = 0U;
 135:usbd_audio.c  ****     audio_streaming_active = 0U;
 136:usbd_audio.c  ****     last_tx_size           = AUDIO_OUT_PACKET;
 137:usbd_audio.c  **** 
 138:usbd_audio.c  ****     if(ITFOPS->Init(USBD_AUDIO_FREQ, AUDIO_DEFAULT_VOLUME, 0U) != 0)
 139:usbd_audio.c  ****         return USBD_FAIL;
 140:usbd_audio.c  **** 
 141:usbd_audio.c  ****     memset(haudio->buffer, 0, sizeof(haudio->buffer));
 142:usbd_audio.c  ****     USBD_LL_Transmit(pdev, AUDIO_IN_EP, haudio->buffer, AUDIO_OUT_PACKET);
 143:usbd_audio.c  ****     return USBD_OK;
 144:usbd_audio.c  **** }
