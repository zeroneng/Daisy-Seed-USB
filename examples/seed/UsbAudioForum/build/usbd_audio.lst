 149:usbd_audio.c  ****     USBD_LL_CloseEP(pdev, AUDIO_IN_EP);
 150:usbd_audio.c  ****     pdev->ep_in[AUDIO_IN_EP & 0x7FU].is_used = 0U;
 151:usbd_audio.c  ****     audio_streaming_active = 0U;
 152:usbd_audio.c  **** 
