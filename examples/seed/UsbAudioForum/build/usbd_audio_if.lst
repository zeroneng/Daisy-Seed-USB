 135:usbd_audio_if.c **** 
 136:usbd_audio_if.c **** /* -----------------------------------------------------------------------
 137:usbd_audio_if.c ****  * copy_frames_from_ring
 138:usbd_audio_if.c ****  *
 139:usbd_audio_if.c ****  * Copies exactly n frames from the ring starting at frame_read into dst,
 140:usbd_audio_if.c ****  * handling the ring wrap-around. Advances frame_read by n.
 141:usbd_audio_if.c ****  * Caller must ensure n <= available frames.
 142:usbd_audio_if.c ****  * --------------------------------------------------------------------- */
 143:usbd_audio_if.c **** static void copy_frames_from_ring(uint8_t *dst, uint32_t n)
 144:usbd_audio_if.c **** {
 145:usbd_audio_if.c ****     uint32_t pos        = frame_read % FRAME_RING_SIZE;
 146:usbd_audio_if.c ****     uint32_t to_end     = FRAME_RING_SIZE - pos;
 147:usbd_audio_if.c **** 
 148:usbd_audio_if.c ****     if(n <= to_end)
 149:usbd_audio_if.c ****     {
 150:usbd_audio_if.c ****         /* Contiguous — single memcpy */
 151:usbd_audio_if.c ****         memcpy(dst, &frame_ring[pos * AUDIO_CHANNELS],
 152:usbd_audio_if.c ****                n * AUDIO_CHANNELS * BYTES_PER_SAMPLE);
 153:usbd_audio_if.c ****     }
 154:usbd_audio_if.c ****     else
 155:usbd_audio_if.c ****     {
 156:usbd_audio_if.c ****         /* Wraps around — two memcpys */
 157:usbd_audio_if.c ****         uint32_t first  = to_end;
 158:usbd_audio_if.c ****         uint32_t second = n - first;
 159:usbd_audio_if.c ****         memcpy(dst,
 160:usbd_audio_if.c ****                &frame_ring[pos * AUDIO_CHANNELS],
 161:usbd_audio_if.c ****                first * AUDIO_CHANNELS * BYTES_PER_SAMPLE);
