   1:usbd_audio_if.c **** /**
   2:usbd_audio_if.c ****  * @file usbd_audio_if.c
   3:usbd_audio_if.c ****  * @brief UAC1 stereo input — 16-bit 48kHz — frame-based ring with drift control
   4:usbd_audio_if.c ****  *
   5:usbd_audio_if.c ****  * =============================================================================
   6:usbd_audio_if.c ****  * WHY A FRAME-BASED RING IS REQUIRED
   7:usbd_audio_if.c ****  * =============================================================================
   8:usbd_audio_if.c ****  *
   9:usbd_audio_if.c ****  * The previous packet-based ring stored 48-frame slots. PeriodicTC always
  10:usbd_audio_if.c ****  * consumed exactly 1 slot per call regardless of whether it sent 47, 48, or
  11:usbd_audio_if.c ****  * 49 bytes to the host. The ring level was therefore unaffected by the
  12:usbd_audio_if.c ****  * correction — drift control had no effect on buffer stability.
  13:usbd_audio_if.c ****  *
  14:usbd_audio_if.c ****  * A frame-based ring stores individual stereo frames. PeriodicTC reads
  15:usbd_audio_if.c ****  * exactly tx_samples frames and advances the read pointer by that amount.
  16:usbd_audio_if.c ****  * Sending 49 frames genuinely drains 49 frames. Sending 47 genuinely drains
  17:usbd_audio_if.c ****  * 47. The buffer level responds correctly to corrections.
  18:usbd_audio_if.c ****  *
  19:usbd_audio_if.c ****  * =============================================================================
  20:usbd_audio_if.c ****  * HOW IT WORKS
  21:usbd_audio_if.c ****  * =============================================================================
  22:usbd_audio_if.c ****  *
  23:usbd_audio_if.c ****  * AudioIF_PushSamples() (audio DMA ISR):
  24:usbd_audio_if.c ****  *   Writes interleaved int16 frames directly into frame_ring[], advancing
  25:usbd_audio_if.c ****  *   frame_write. No partial-packet accumulation needed — any number of
  26:usbd_audio_if.c ****  *   frames per call is accepted.
  27:usbd_audio_if.c ****  *
  28:usbd_audio_if.c ****  * Audio_PeriodicTC() (USB DataIn ISR, every 1ms):
  29:usbd_audio_if.c ****  *   1. Computes available = frame_write - frame_read (in frames)
  30:usbd_audio_if.c ****  *   2. Decides tx_samples: 47, 48, or 49 based on level vs target
ARM GAS  /tmp/ccVgpXxR.s 			page 2


  31:usbd_audio_if.c ****  *   3. Copies exactly tx_samples frames from ring into pbuf (handles wrap)
  32:usbd_audio_if.c ****  *   4. Advances frame_read by tx_samples
  33:usbd_audio_if.c ****  *   5. Returns byte count → DataIn passes to USBD_LL_Transmit
  34:usbd_audio_if.c ****  *
  35:usbd_audio_if.c ****  * =============================================================================
  36:usbd_audio_if.c ****  * TUNING
  37:usbd_audio_if.c ****  * =============================================================================
  38:usbd_audio_if.c ****  *
  39:usbd_audio_if.c ****  * FRAME_RING_SIZE (default 512 = 10.67ms at 48kHz)
  40:usbd_audio_if.c ****  *   Must be power of 2. Total memory = SIZE * 2ch * 2B = SIZE * 4 bytes.
  41:usbd_audio_if.c ****  *   512 → 2048 bytes. 1024 → 4096 bytes.
  42:usbd_audio_if.c ****  *
  43:usbd_audio_if.c ****  * FRAME_TARGET (default FRAME_RING_SIZE/2 = 256 frames = 5.3ms)
  44:usbd_audio_if.c ****  *   Steady-state fill level. Half the ring gives equal overflow/underrun margin.
  45:usbd_audio_if.c ****  *
  46:usbd_audio_if.c ****  * FRAME_DRIFT_THRESH (default 96 frames = 2ms)
  47:usbd_audio_if.c ****  *   Deadband half-width in frames. Corrections fire when level strays more
  48:usbd_audio_if.c ****  *   than this many frames from FRAME_TARGET.
  49:usbd_audio_if.c ****  *   Smaller = more aggressive, more frequent corrections, very stable.
  50:usbd_audio_if.c ****  *   Larger  = gentler, less frequent, more natural sounding.
  51:usbd_audio_if.c ****  *   Rule of thumb: FRAME_RING_SIZE / 8 is a good starting point.
  52:usbd_audio_if.c ****  *
  53:usbd_audio_if.c ****  * DIAGNOSTICS (read via LED pattern in main loop)
  54:usbd_audio_if.c ****  *   drift_corrections_up    — 49-sample packets sent (buffer was above HIGH)
  55:usbd_audio_if.c ****  *   drift_corrections_down  — 47-sample packets sent (buffer was below LOW)
  56:usbd_audio_if.c ****  *   underrun_events         — buffer hit zero (should always be 0)
  57:usbd_audio_if.c ****  *
  58:usbd_audio_if.c ****  *   Healthy: up and down both nonzero and slowly incrementing, underrun = 0.
  59:usbd_audio_if.c ****  *   up >> down:  audio clock faster than USB — normal.
  60:usbd_audio_if.c ****  *   down >> up:  audio clock slower than USB — normal.
  61:usbd_audio_if.c ****  *   underrun > 0: increase FRAME_RING_SIZE or FRAME_TARGET.
  62:usbd_audio_if.c ****  */
  63:usbd_audio_if.c **** 
  64:usbd_audio_if.c **** #include "usbd_audio_if.h"
  65:usbd_audio_if.c **** #include "stm32h7xx_hal.h"
  66:usbd_audio_if.c **** #include <string.h>
  67:usbd_audio_if.c **** #include <stdint.h>
  68:usbd_audio_if.c **** 
  69:usbd_audio_if.c **** /* -----------------------------------------------------------------------
  70:usbd_audio_if.c ****  * Audio geometry — must match descriptor in usbd_audio.c
  71:usbd_audio_if.c ****  * --------------------------------------------------------------------- */
  72:usbd_audio_if.c **** #define AUDIO_SAMPLE_RATE   48000U
  73:usbd_audio_if.c **** #define AUDIO_CHANNELS      2U
  74:usbd_audio_if.c **** #define BYTES_PER_SAMPLE    2U
  75:usbd_audio_if.c **** #define SAMPLES_NOM         (AUDIO_SAMPLE_RATE / 1000U)            /* 48 */
  76:usbd_audio_if.c **** #define SAMPLES_MAX         (SAMPLES_NOM + 1U)                     /* 49 */
  77:usbd_audio_if.c **** #define SAMPLES_MIN         (SAMPLES_NOM - 1U)                     /* 47 */
  78:usbd_audio_if.c **** #define BYTES_NOM           (SAMPLES_NOM * AUDIO_CHANNELS * BYTES_PER_SAMPLE)  /* 192 */
  79:usbd_audio_if.c **** #define BYTES_MAX           (SAMPLES_MAX * AUDIO_CHANNELS * BYTES_PER_SAMPLE)  /* 196 */
  80:usbd_audio_if.c **** #define BYTES_MIN           (SAMPLES_MIN * AUDIO_CHANNELS * BYTES_PER_SAMPLE)  /* 188 */
  81:usbd_audio_if.c **** 
  82:usbd_audio_if.c **** /* -----------------------------------------------------------------------
  83:usbd_audio_if.c ****  * Tuning knobs — adjust these three values only
  84:usbd_audio_if.c ****  * --------------------------------------------------------------------- */
  85:usbd_audio_if.c **** #define FRAME_RING_SIZE     512U    /* ring depth in frames — power of 2, 512=10.67ms */
  86:usbd_audio_if.c **** #define FRAME_TARGET        256U    /* target fill level = FRAME_RING_SIZE / 2        */
  87:usbd_audio_if.c **** #define FRAME_DRIFT_THRESH   64U    /* deadband half-width in frames                  */
ARM GAS  /tmp/ccVgpXxR.s 			page 3


  88:usbd_audio_if.c **** 
  89:usbd_audio_if.c **** /* Derived watermarks — do not edit */
  90:usbd_audio_if.c **** #define FRAME_DRIFT_HIGH    (FRAME_TARGET + FRAME_DRIFT_THRESH)   /* 320 */
  91:usbd_audio_if.c **** #define FRAME_DRIFT_LOW     (FRAME_TARGET - FRAME_DRIFT_THRESH)   /* 192 */
  92:usbd_audio_if.c **** 
  93:usbd_audio_if.c **** /* -----------------------------------------------------------------------
  94:usbd_audio_if.c ****  * Diagnostics counters
  95:usbd_audio_if.c ****  * --------------------------------------------------------------------- */
  96:usbd_audio_if.c **** volatile uint32_t drift_corrections_up   = 0U;
  97:usbd_audio_if.c **** volatile uint32_t drift_corrections_down = 0U;
  98:usbd_audio_if.c **** volatile uint32_t underrun_events        = 0U;
  99:usbd_audio_if.c **** 
 100:usbd_audio_if.c **** /* -----------------------------------------------------------------------
 101:usbd_audio_if.c ****  * Frame ring buffer
 102:usbd_audio_if.c ****  *
 103:usbd_audio_if.c ****  * Stored as flat interleaved int16: [L0,R0, L1,R1, ... L511,R511]
 104:usbd_audio_if.c ****  * Total size = 512 * 2 * 2 = 2048 bytes
 105:usbd_audio_if.c ****  *
 106:usbd_audio_if.c ****  * DSY_RAM_D2 = D2 SRAM (non-cacheable) — safe for USB DMA reads.
 107:usbd_audio_if.c ****  * --------------------------------------------------------------------- */
 108:usbd_audio_if.c **** static __attribute__((section(".heap"))) int16_t  frame_ring[FRAME_RING_SIZE * AUDIO_CHANNELS] ;
 109:usbd_audio_if.c **** 
 110:usbd_audio_if.c **** static volatile uint32_t frame_write = 0U;   /* next write position in frames */
 111:usbd_audio_if.c **** static volatile uint32_t frame_read  = 0U;   /* next read  position in frames */
 112:usbd_audio_if.c **** static          uint8_t  streaming_active = 0U;
 113:usbd_audio_if.c **** 
 114:usbd_audio_if.c **** /* -----------------------------------------------------------------------
 115:usbd_audio_if.c ****  * Init
 116:usbd_audio_if.c ****  * --------------------------------------------------------------------- */
 117:usbd_audio_if.c **** static  int8_t Audio_Init(uint32_t AudioFreq, uint32_t Volume, uint32_t options)
 118:usbd_audio_if.c **** {
 119:usbd_audio_if.c ****     (void)AudioFreq; (void)Volume; (void)options;
 120:usbd_audio_if.c ****     frame_write            = 0U;
 121:usbd_audio_if.c ****     frame_read             = 0U;
 122:usbd_audio_if.c ****     streaming_active       = 0U;
 123:usbd_audio_if.c ****     drift_corrections_up   = 0U;
 124:usbd_audio_if.c ****     drift_corrections_down = 0U;
 125:usbd_audio_if.c ****     underrun_events        = 0U;
 126:usbd_audio_if.c ****     memset(frame_ring, 0, sizeof(frame_ring));
 127:usbd_audio_if.c ****     return USBD_OK;
 128:usbd_audio_if.c **** }
