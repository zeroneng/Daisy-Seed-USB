 141:usbd_desc.c   **** /* -------------------------------------------------------------------------- */
 142:usbd_desc.c   **** static void IntToUnicode(uint32_t value, uint8_t *pbuf, uint8_t len)
 143:usbd_desc.c   **** {
ARM GAS  /tmp/ccRhEz3e.s 			page 4


 144:usbd_desc.c   ****     for(uint8_t idx = 0; idx < len; idx++)
 145:usbd_desc.c   ****     {
 146:usbd_desc.c   ****         uint8_t nib = (value >> 28) & 0x0F;
 147:usbd_desc.c   ****         pbuf[2 * idx]     = (nib < 10) ? ('0' + nib) : ('A' + nib - 10);
 148:usbd_desc.c   ****         pbuf[2 * idx + 1] = 0;
 149:usbd_desc.c   ****         value <<= 4;
 150:usbd_desc.c   ****     }
 151:usbd_desc.c   **** }
 152:usbd_desc.c   **** 
 153:usbd_desc.c   **** static void Get_SerialNum(void)
 154:usbd_desc.c   **** {
 155:usbd_desc.c   ****     uint32_t deviceserial0 = *(uint32_t *)DEVICE_ID1;
 156:usbd_desc.c   ****     uint32_t deviceserial1 = *(uint32_t *)DEVICE_ID2;
 157:usbd_desc.c   ****     uint32_t deviceserial2 = *(uint32_t *)DEVICE_ID3;
 158:usbd_desc.c   ****     deviceserial0 += deviceserial2;
 159:usbd_desc.c   ****     if(deviceserial0 != 0)
 160:usbd_desc.c   ****     {
 161:usbd_desc.c   ****         IntToUnicode(deviceserial0, &USBD_StringSerial[2],  8);
 162:usbd_desc.c   ****         IntToUnicode(deviceserial1, &USBD_StringSerial[18], 4);
 163:usbd_desc.c   ****     }
 164:usbd_desc.c   **** }
