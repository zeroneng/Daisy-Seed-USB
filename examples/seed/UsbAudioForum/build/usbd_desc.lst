  18:usbd_desc.c   **** /* Device identification                                                       */
  19:usbd_desc.c   **** /* -------------------------------------------------------------------------- */
  20:usbd_desc.c   **** #define USBD_VID                    1155       /* 0x0483 — ST's VID, ok for dev */
  21:usbd_desc.c   **** #define USBD_LANGID_STRING          1033       /* English */
  22:usbd_desc.c   **** #define USBD_MANUFACTURER_STRING    "Electrosmith"
  23:usbd_desc.c   **** 
  24:usbd_desc.c   **** /* Internal FS connector — the one on the Daisy Seed board */
  25:usbd_desc.c   **** #define USBD_PID_FS                 0x5741
  26:usbd_desc.c   **** #define USBD_PRODUCT_STRING_FS      "JamMate Audio In"
  27:usbd_desc.c   **** #define USBD_CONFIGURATION_STRING_FS "Audio Config"
  28:usbd_desc.c   **** #define USBD_INTERFACE_STRING_FS    "Audio Streaming"
  29:usbd_desc.c   **** 
ARM GAS  /tmp/ccRhEz3e.s 			page 2


  30:usbd_desc.c   **** /* External HS connector — not present on Daisy Seed, keep for completeness */
  31:usbd_desc.c   **** #define USBD_PID_HS                 0x5742
  32:usbd_desc.c   **** #define USBD_PRODUCT_STRING_HS      "JamMate Audio In HS"
  33:usbd_desc.c   **** #define USBD_CONFIGURATION_STRING_HS "Audio Config"
  34:usbd_desc.c   **** #define USBD_INTERFACE_STRING_HS    "Audio Streaming"
