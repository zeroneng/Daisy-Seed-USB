   1:usbd_desc.c   **** /**
   2:usbd_desc.c   ****   ******************************************************************************
   3:usbd_desc.c   ****   * @file    usbd_desc.c
   4:usbd_desc.c   ****   * @brief   USB Device descriptors for Daisy Seed UAC1 Microphone
   5:usbd_desc.c   ****   *
   6:usbd_desc.c   ****   * Change from CDC baseline: product/config/interface strings updated from
   7:usbd_desc.c   ****   * "CDC Config" / "CDC Interface" to "Audio Config" / "Audio Streaming".
   8:usbd_desc.c   ****   * PID changed from 22336 (0x5740, ST's CDC PID) to 0x5741 so Windows doesn't
   9:usbd_desc.c   ****   * confuse this with a previously-seen CDC device.
  10:usbd_desc.c   ****   ******************************************************************************
  11:usbd_desc.c   ****   */
