  29:usb_descriptors.c **** /* A combination of interfaces must have a unique product id, since PC will save device driver afte
  30:usb_descriptors.c ****  * Same VID/PID with different interface e.g MSC (first), then CDC (later) will possibly cause syst
ARM GAS  /tmp/cc1BqBh9.s 			page 2


  31:usb_descriptors.c ****  *
  32:usb_descriptors.c ****  * Auto ProductID layout's Bitmap:
  33:usb_descriptors.c ****  *   [MSB]         HID | MSC | CDC          [LSB]
  34:usb_descriptors.c ****  */
  35:usb_descriptors.c **** #define PID_MAP(itf, n)  ((CFG_TUD_##itf) ? (1 << (n)) : 0)
  36:usb_descriptors.c **** #define USB_PID           (0x4000 | PID_MAP(CDC, 0) | PID_MAP(MSC, 1) | PID_MAP(HID, 2) | \
  37:usb_descriptors.c ****                            PID_MAP(MIDI, 3) | PID_MAP(VENDOR, 4) )
  38:usb_descriptors.c **** 
  39:usb_descriptors.c **** #define USB_VID   0xCafe
  40:usb_descriptors.c **** #define USB_BCD   0x0200
  41:usb_descriptors.c **** 
  42:usb_descriptors.c **** static tusb_desc_device_t const desc_device = {
  43:usb_descriptors.c ****     .bLength            = sizeof(tusb_desc_device_t),
  44:usb_descriptors.c ****     .bDescriptorType    = TUSB_DESC_DEVICE,
  45:usb_descriptors.c ****     .bcdUSB             = USB_BCD,
  46:usb_descriptors.c ****     .bDeviceClass       = TUSB_CLASS_MISC,
  47:usb_descriptors.c ****     .bDeviceSubClass    = MISC_SUBCLASS_COMMON,
  48:usb_descriptors.c ****     .bDeviceProtocol    = MISC_PROTOCOL_IAD,
  49:usb_descriptors.c ****     .bMaxPacketSize0    = CFG_TUD_ENDPOINT0_SIZE,
  50:usb_descriptors.c ****     .idVendor           = USB_VID,
  51:usb_descriptors.c ****     .idProduct          = USB_PID,
  52:usb_descriptors.c ****     .bcdDevice          = 0x0100,
  53:usb_descriptors.c ****     .iManufacturer      = 0x01,
  54:usb_descriptors.c ****     .iProduct           = 0x02,
  55:usb_descriptors.c ****     .iSerialNumber      = 0x03,
  56:usb_descriptors.c ****     .bNumConfigurations = 0x01
  57:usb_descriptors.c **** };
