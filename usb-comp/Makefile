TARGET = UsbComp

LIBDAISY_DIR = ../../libDaisy
OPT = -Ofast
ST_USB_DEVICE_DIR = vendor/stm32_mw_usb_device
USBD_CMPSIT_ACTIVATE_CDC ?= 1
USBD_CMPSIT_ACTIVATE_HID ?= 1
USBD_CMPSIT_ACTIVATE_AUDIO ?= 1
USBD_CMPSIT_ACTIVATE_MIDI ?= 1
USB_COMP_TEST_CDC ?= 0
USB_COMP_TEST_HID ?= 0
USB_COMP_TEST_MIDI ?= 0
USB_COMP_TEST_AUDIO ?= 0
USB_COMP_AUDIO_START_ON_BOOT ?= 1

CPP_SOURCES = \
UsbComp.cpp
C_SOURCES += \
usbd_conf.c \
usbd_desc.c \
usbd_composite_builder.c \
$(ST_USB_DEVICE_DIR)/Core/Src/usbd_core.c \
$(ST_USB_DEVICE_DIR)/Core/Src/usbd_ctlreq.c \
$(ST_USB_DEVICE_DIR)/Core/Src/usbd_ioreq.c

ifeq ($(USBD_CMPSIT_ACTIVATE_CDC),1)
C_SOURCES += \
usb_comp_cdc_if.c \
$(ST_USB_DEVICE_DIR)/Class/CDC/Src/usbd_cdc.c
endif

ifeq ($(USBD_CMPSIT_ACTIVATE_HID),1)
C_SOURCES += \
usbd_hid_kbd.c
endif

ifeq ($(USBD_CMPSIT_ACTIVATE_AUDIO),1)
C_SOURCES += \
usbd_audio.c \
usbd_audio_if.c
endif

ifeq ($(USBD_CMPSIT_ACTIVATE_MIDI),1)
C_SOURCES += \
usbd_midi.c
endif

C_INCLUDES += \
-I. \
-Ivendor/hid/Inc \
-I$(ST_USB_DEVICE_DIR)/Core/Inc \
-I$(ST_USB_DEVICE_DIR)/Class/CDC/Inc \
-I$(ST_USB_DEVICE_DIR)/Class/HID/Inc \
-I$(ST_USB_DEVICE_DIR)/Class/CompositeBuilder/Inc \
-I$(LIBDAISY_DIR)/src/usbd

C_DEFS += \
-DUSE_USBD_COMPOSITE \
-DUSBD_CMPSIT_ACTIVATE_CDC=$(USBD_CMPSIT_ACTIVATE_CDC) \
-DUSBD_CMPSIT_ACTIVATE_HID=$(USBD_CMPSIT_ACTIVATE_HID) \
-DUSBD_CMPSIT_ACTIVATE_AUDIO=$(USBD_CMPSIT_ACTIVATE_AUDIO) \
-DUSBD_CMPSIT_ACTIVATE_MIDI=$(USBD_CMPSIT_ACTIVATE_MIDI) \
-DUSB_COMP_AUDIO_START_ON_BOOT=$(USB_COMP_AUDIO_START_ON_BOOT) \
-DHID_FS_BINTERVAL=0x01U

ifneq ($(USB_COMP_AUDIO_CAPTURE_RING_SIZE),)
C_DEFS += -DUSB_COMP_AUDIO_CAPTURE_RING_SIZE=$(USB_COMP_AUDIO_CAPTURE_RING_SIZE)
endif

ifneq ($(USB_COMP_AUDIO_PLAYBACK_RING_SIZE),)
C_DEFS += -DUSB_COMP_AUDIO_PLAYBACK_RING_SIZE=$(USB_COMP_AUDIO_PLAYBACK_RING_SIZE)
endif

ifeq ($(USB_COMP_TEST_CDC),1)
C_DEFS += -DUSB_COMP_TEST_CDC=1
endif

ifeq ($(USB_COMP_TEST_HID),1)
C_DEFS += -DUSB_COMP_TEST_HID=1
endif

ifeq ($(USB_COMP_TEST_AUDIO),1)
C_DEFS += -DUSB_COMP_TEST_AUDIO=1
endif

ifeq ($(USB_COMP_TEST_MIDI),1)
C_DEFS += -DUSB_COMP_TEST_MIDI=1
endif

USE_FATFS = 0

SYSTEM_FILES_DIR = $(LIBDAISY_DIR)/core
include $(SYSTEM_FILES_DIR)/Makefile
